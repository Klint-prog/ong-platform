# ─────────────────────────────────────────────────────────
#  ONG Platform — Variáveis de ambiente
#  Copie este arquivo para .env e ajuste os valores
#  NUNCA suba o .env para o Git!
# ─────────────────────────────────────────────────────────

# ── Frontend ──────────────────────────────────────────────
FRONTEND_PORT=8977

# ── Banco de dados ────────────────────────────────────────
DB_NAME=ong_platform
DB_USER=ong
DB_PASSWORD=troque-esta-senha
POSTGRES_PORT=5433

# ── Backend ───────────────────────────────────────────────
# Tamanho máximo de upload em bytes (padrão: 50 MB)
MAX_FILE_SIZE=52428800

# Habilite CORS apenas se acessar a API de outra origem (ex.: dev do Vite)
# CORS_ORIGIN=http://localhost:5173
